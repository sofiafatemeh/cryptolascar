# =============================================================================
# CryptoLascar — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS commiter .env dans git
# =============================================================================

# --- SMTP / Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Liste de destinataires (séparés par virgule, sans espaces)
RECIPIENT_LIST=recipient@example.com

# --- Anthropic / Claude LLM ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Modèle utilisé pour la synthèse narrative (défaut recommandé : claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- APIs de données financières ---
COINGECKO_API_KEY=your_coingecko_api_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
FRED_API_KEY=your_fred_api_key
NEWSAPI_KEY=your_newsapi_key

# --- Base de données SQLite ---
# Chemin relatif depuis la racine du projet
DB_PATH=cryptolascar.db

# --- Logging ---
# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Chemin du fichier de log (optionnel — si vide, log uniquement en stdout)
LOG_FILE=cryptolascar.log
